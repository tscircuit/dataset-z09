{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "lib": ["ES2023", "WebWorker", "DOM"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts"]
}
